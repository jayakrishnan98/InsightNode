# Copy to .env for local overrides (never commit .env with real secrets).

# Grafana admin (lab defaults — change for any shared/cloud deploy)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ClickHouse (Grafana container uses these; host matches docker-compose defaults)
CLICKHOUSE_USER=insightnode
CLICKHOUSE_PASSWORD=insightnode
CLICKHOUSE_DATABASE=insightnode

# PostgreSQL — host DB reachable from Grafana via host.docker.internal
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=insightnode
POSTGRES_PASSWORD=insightnode
POSTGRES_DATABASE=insightnode

# Worker Prometheus scrape port (API uses :8001/prometheus)
WORKER_METRICS_PORT=8002

# Grafana → API alert webhook (Authorization: Bearer …)
GRAFANA_WEBHOOK_SECRET=dev-webhook-secret

# Public Grafana URL (system summary + host deep links)
GRAFANA_PUBLIC_URL=http://localhost:3000

# Custom UI (frontend/.env.local) — server-side API access only
# INSIGHTNODE_API_BASE=http://127.0.0.1:8001
# INSIGHTNODE_API_KEY=dev-local-key
# NEXT_PUBLIC_GRAFANA_URL=http://localhost:3000
