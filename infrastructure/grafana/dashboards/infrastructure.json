      "title": "Host Status / Last Seen",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "insightnode-clickhouse" },
          "editorType": "sql",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  machine_id,\n  max(timestamp) AS last_seen,\n  dateDiff('second', max(timestamp), now()) AS seconds_ago,\n  if(dateDiff('second', max(timestamp), now()) <= 120, 'online', 'offline') AS status\nFROM insightnode.metrics\nWHERE tenant_id = '${tenant_id}'\n  AND ('${machine_id}' = '' OR has(splitByChar(',', '${machine_id}'), machine_id))\nGROUP BY machine_id\nORDER BY last_seen DESC",
          "refId": "A"
