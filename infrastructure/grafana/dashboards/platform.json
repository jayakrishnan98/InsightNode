        {
          "datasource": { "type": "prometheus", "uid": "insightnode-prometheus" },
          "expr": "sum(rate(insightnode_ingest_rejected_total[1m])) by (reason)",
          "legendFormat": "rejected {{reason}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "insightnode-prometheus" },
