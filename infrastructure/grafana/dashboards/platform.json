      "title": "HTTP Request Latency (p95)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "insightnode-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(insightnode_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "insightnode-prometheus" },
